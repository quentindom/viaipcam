---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site.js';

const areaLabel = site.areaServed.slice(0, 3).join(' · ');
---

<Layout
  title={`${site.person.full} — ${site.tagline} | Roanne`}
  description="Vincent Domenjoud, installateur indépendant : caméras IP, alarmes, réseau Wi-Fi et câblage, antennes et informatique à Roanne, Lyon et Clermont-Ferrand. Devis gratuit."
>
  <Header />

  <main>
    <section class="py-16 bg-gradient-to-b from-white to-surface">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <img
          src={site.assets.portrait}
          alt={site.assets.portraitAlt}
          class="mx-auto rounded-2xl w-full max-w-xs aspect-square object-cover shadow-xl border-4 border-white mb-8"
          width="320"
          height="320"
          fetchpriority="high"
          loading="eager"
        />
        <h1 class="text-3xl md:text-5xl font-bold text-primary mb-3">
          {site.person.full}
        </h1>
        <p class="text-lg md:text-xl text-slate-600 mb-2">{site.tagline}</p>
        <p class="text-sm text-slate-500 mb-8">
          {site.name} · {areaLabel}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`tel:${site.contact.phone}`} class={site.styles.ctaButton}>
            {site.contact.phoneDisplay}
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center leading-none px-8 py-3.5 rounded-full text-lg font-medium border-2 border-primary text-primary hover:bg-primary hover:text-white transition-all"
          >
            Demander un devis
          </a>
        </div>
        <p class="mt-6">
          <a href="/a-propos" class="text-accent font-medium hover:underline">
            En savoir plus sur Vincent →
          </a>
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-8">
      <h2 class="text-2xl font-bold text-primary text-center mb-8">Mes prestations principales</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {site.services.featured.map((service) => (
          <a
            href={service.href}
            class="bg-white rounded-2xl shadow overflow-hidden flex flex-col hover:shadow-lg transition group"
          >
            <img
              src={service.image}
              alt=""
              class="w-full h-48 object-cover"
              width="600"
              height="192"
              loading="lazy"
            />
            <div class="p-8 flex flex-col flex-1">
              <h3 class="text-xl font-semibold mb-3 text-primary group-hover:text-accent transition-colors">
                {service.title}
              </h3>
              <p class="text-slate-600 flex-1 leading-relaxed" set:html={service.description} />
              <span class="mt-6 text-accent font-medium">En savoir plus →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-16">
      <div class="grid sm:grid-cols-2 gap-8">
        {site.services.secondary.map((service) => (
          <a
            href={service.href}
            class="bg-white rounded-2xl shadow p-8 flex flex-col hover:shadow-lg transition"
          >
            <h3 class="text-xl font-semibold mb-3 text-primary">{service.title}</h3>
            <p class="text-slate-600 flex-1 leading-relaxed">{service.description}</p>
            <span class="mt-6 text-accent font-medium">En savoir plus →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="bg-white border-y border-slate-200 py-12">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-2xl font-bold text-primary mb-4">Un artisan de confiance</h2>
        <p class="text-slate-700 leading-relaxed">
          Je travaille seul et quasiment uniquement par recommandation. Chaque projet commence par
          une étude sur place et un devis gratuit, que vous soyez particulier ou TPE.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <h2 class="text-2xl font-bold text-primary">Quelques réalisations</h2>
        <a href="/realisations" class="text-accent font-medium hover:underline">
          Voir toutes les réalisations →
        </a>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {site.realisations.slice(0, 3).map((item) => (
          <div class="bg-white rounded-xl shadow overflow-hidden">
            <img
              src={item.image}
              alt=""
              class="w-full h-40 object-cover"
              width="400"
              height="160"
              loading="lazy"
            />
            <div class="p-4">
              <p class="font-medium text-primary">{item.title}</p>
              <p class="text-sm text-slate-500">{item.location}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-primary text-white py-12">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-2xl font-bold mb-4">Zone d'intervention</h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          Roanne, Lyon, Clermont-Ferrand et l'ensemble de l'Auvergne-Rhône-Alpes.
        </p>
        <a
          href={`mailto:${site.contact.email}`}
          class="inline-flex items-center justify-center leading-none bg-cta hover:opacity-90 text-white px-8 py-3.5 rounded-full text-lg font-medium transition-all"
        >
          {site.contact.email}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
