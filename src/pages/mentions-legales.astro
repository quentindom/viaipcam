---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../config/site.js';

const legalAddress = `${site.address.street} — ${site.address.postalCode} ${site.address.city}`;
---

<PageLayout
  title={`Mentions légales | ${site.seo.titleSuffixLegal}`}
  description={`Mentions légales du site ${site.name} — éditeur, hébergeur, données personnelles, cookies.`}
>
  <h1 class={site.styles.h1}>Mentions légales</h1>

  <div class="space-y-8 text-slate-700 leading-relaxed text-sm">
    <section>
      <h2 class={site.styles.h2Sub}>Éditeur</h2>
      <p>Raison sociale : {site.name}</p>
      <p>Représentant : {site.person.fullCaps}</p>
      <p>SIRET : {site.legal.siret}</p>
      <p>Siège social : {legalAddress}</p>
      <p>Tél : {site.contact.phoneDisplay}</p>
      <p>Mail : {site.contact.email}</p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Hébergeur</h2>
      <p>{site.legal.host.name} — {site.legal.host.company}</p>
      <p>{site.legal.host.address}</p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Réalisation</h2>
      <p>{site.legal.credits}</p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Loi applicable</h2>
      <p>Le contenu de ce site est régi par la loi française.</p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Données personnelles</h2>
      <p>
        Les données collectées par le biais du site sont destinées exclusivement à {site.name}.
        Vous pouvez à tout moment exercer votre droit d'accès, d'opposition, de retrait et de
        rectification en écrivant à {site.contact.email}.
      </p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Cookies</h2>
      <p>
        Le site statique n'utilise pas de cookies de tracking. Si des statistiques sont
        ajoutées ultérieurement, cette section sera mise à jour.
      </p>
    </section>

    <section>
      <h2 class={site.styles.h2Sub}>Propriété intellectuelle</h2>
      <p>
        Toute reproduction du site ou de ses éléments sans accord écrit préalable de {site.name}
        est interdite.
      </p>
    </section>
  </div>
</PageLayout>
