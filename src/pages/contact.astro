---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../config/site.js';

const inputClass =
  'w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/40';
---

<PageLayout
  title={`Contact | ${site.seo.titleSuffix}`}
  description="Contactez Vincent Domenjoud pour un devis gratuit. Téléphone et email — Roanne, Lyon, Clermont-Ferrand et Auvergne-Rhône-Alpes."
>
  <img
    src={site.assets.portrait}
    alt={site.assets.portraitAlt}
    class={site.styles.portrait}
    width="416"
    height="416"
    loading="eager"
  />

  <h1 class={site.styles.h1}>Contactez Vincent</h1>
  <p class="text-slate-600 mb-8">
    Je vous réponds dans les plus brefs délais pour toute demande de renseignements ou de devis.
  </p>

  <div class="space-y-6 text-lg mb-10 pb-10 border-b border-slate-200">
    <p>
      <span class="font-medium text-primary block mb-1">Téléphone</span>
      <a href={`tel:${site.contact.phone}`} class="text-accent hover:underline text-2xl font-semibold">
        {site.contact.phoneDisplay}
      </a>
    </p>
    <p>
      <span class="font-medium text-primary block mb-1">Email</span>
      <a href={`mailto:${site.contact.email}`} class="text-accent hover:underline">
        {site.contact.email}
      </a>
    </p>
  </div>

  <section>
    <h2 class={site.styles.h2Sub}>Envoyez un message</h2>

    <form
      id="contact-form"
      class="mt-6 space-y-5"
      method="POST"
      action={site.integrations.formspree.action}
    >
      <input type="hidden" name="_subject" value={site.integrations.formspree.subject} />
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

      <div>
        <label for="nom" class="block text-sm font-medium text-primary mb-2">
          Nom <span class="text-accent">*</span>
        </label>
        <input type="text" id="nom" name="nom" required class={inputClass} />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-primary mb-2">
          Email <span class="text-accent">*</span>
        </label>
        <input type="email" id="email" name="email" required class={inputClass} />
      </div>

      <div>
        <label for="telephone" class="block text-sm font-medium text-primary mb-2">
          Téléphone <span class="text-accent">*</span>
        </label>
        <input type="tel" id="telephone" name="telephone" required class={inputClass} />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-primary mb-2">
          Message <span class="text-accent">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class={`${inputClass} resize-y`}
        ></textarea>
      </div>

      <button id="contact-submit" type="submit" class={`w-full disabled:opacity-60 ${site.styles.ctaButton}`}>
        Envoyer
      </button>

      <p id="contact-error" class="hidden text-sm text-red-600 text-center" role="alert">
        Une erreur est survenue. Veuillez réessayer ou me contacter par téléphone.
      </p>

      <p class="text-sm text-slate-500 text-center">
        Vos données sont utilisées uniquement pour répondre à votre demande.{' '}
        <a href="/mentions-legales" class="text-accent hover:underline">
          Politique de confidentialité
        </a>
      </p>
    </form>
  </section>

  <div class="mt-10 pt-8 border-t border-slate-200">
    <h2 class={site.styles.h2Sub}>Zone d'intervention</h2>
    <p class="text-slate-700">
      Roanne, Lyon, Clermont-Ferrand et l'ensemble de l'Auvergne-Rhône-Alpes.
    </p>
  </div>

  {site.googleBusiness && (
    <p class="mt-6">
      <a
        href={site.googleBusiness}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent font-medium hover:underline"
      >
        Voir la fiche Google →
      </a>
    </p>
  )}
</PageLayout>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const errorMsg = document.getElementById('contact-error');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !submitBtn || !errorMsg) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours…';
    errorMsg.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        window.location.href = '/merci';
        return;
      }

      throw new Error('Formspree error');
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Envoyer';
    }
  });
</script>
