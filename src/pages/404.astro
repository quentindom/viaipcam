---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site.js';
---

<Layout
  title={`Page introuvable | ${site.seo.titleSuffix}`}
  description="Cette page n'existe pas ou a été déplacée."
  noindex={true}
>
  <Header />

  <main>
    <section class="max-w-3xl mx-auto px-6 py-24 text-center">
      <p class="text-6xl font-bold text-slate-300 mb-4" aria-hidden="true">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-primary mb-4">Page introuvable</h1>
      <p class="text-slate-600 mb-8 leading-relaxed">
        Cette adresse n'existe pas ou la page a été déplacée. Utilisez le menu ou revenez à
        l'accueil.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class={site.styles.ctaButton}>Retour à l'accueil</a>
        <a href="/contact" class={site.styles.secondaryButton}>Me contacter</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
