---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../config/site.js';
---

<PageLayout
  title={`${site.person.full} — Installateur indépendant | Roanne`}
  description="Vincent Domenjoud, installateur indépendant à Roanne. Caméras, réseau, antennes et informatique pour particuliers et TPE. Devis gratuit."
>
  <img
    src={site.assets.portrait}
    alt={site.assets.portraitAlt}
    class="w-full max-w-sm rounded-xl mb-8 object-cover aspect-square"
    width="384"
    height="384"
    loading="eager"
  />

  <h1 class="text-3xl font-bold text-primary mb-6">
    {site.person.full}, installateur indépendant
  </h1>

  <div class="space-y-4 text-slate-700 leading-relaxed">
    <p>
      Sous l'enseigne <strong>{site.name}</strong>, j'interviens à domicile et en entreprise pour
      installer, dépanner et conseiller — caméras IP, alarmes, réseau Wi-Fi et câblage, antennes
      et accompagnement informatique.
    </p>
    <p>
      Je travaille seul et quasiment uniquement par recommandation. Chaque projet commence par
      une rencontre sur place pour comprendre votre besoin, puis un devis gratuit sans engagement.
    </p>
    <p>
      J'accompagne aussi bien les particuliers que les TPE : maisons, commerces, garages distants,
      locaux professionnels…
    </p>
    <p class="font-medium text-primary">
      Roanne, Lyon, Clermont-Ferrand et l'Auvergne-Rhône-Alpes.
    </p>
  </div>

  <div class="mt-10 flex flex-col sm:flex-row gap-4">
    <a href={`tel:${site.contact.phone}`} class={site.styles.ctaButton + ' text-center'}>
      {site.contact.phoneDisplay}
    </a>
    <a
      href="/contact"
      class="inline-block px-8 py-4 rounded-full text-lg font-medium border-2 border-primary text-primary hover:bg-primary hover:text-white transition-all text-center"
    >
      Me contacter
    </a>
  </div>
</PageLayout>
