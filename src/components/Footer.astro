---
import { site } from '../config/site.js';
---

<footer class="bg-white border-t border-slate-200 py-12 mt-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <a href="/" class="inline-block mb-4">
          <img
            src={site.assets.logo}
            alt={site.assets.logoAlt}
            class="h-10 sm:h-11 w-auto"
            width="560"
            height="120"
            loading="lazy"
          />
        </a>
        <p class="text-sm text-slate-600">{site.person.full}</p>
        <p class="text-sm text-slate-600 mt-1">{site.tagline}</p>
        <p class="text-sm text-slate-600 mt-2">
          {site.areaServed.slice(0, 3).join(' · ')}
        </p>
      </div>

      <div class="text-sm">
        <h2 class="font-medium mb-3 text-primary">Navigation</h2>
        <ul class="space-y-2 text-slate-600">
          {site.footerExtra.map((link) => (
            <li><a href={link.href} class="hover:text-primary">{link.label}</a></li>
          ))}
          {site.nav.map((link) => (
            <li><a href={link.href} class="hover:text-primary">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="text-sm">
        <h2 class="font-medium mb-3 text-primary">Contact</h2>
        <div class="flex gap-4 mb-4">
          <a
            href={site.social.linkedin}
            aria-label="LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-cta transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
            </svg>
          </a>
          <a
            href={site.social.facebook}
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-cta transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
            </svg>
          </a>
          <a
            href={`https://wa.me/${site.contact.phoneWhatsApp}`}
            aria-label="WhatsApp"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-cta transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.85.326 1.14.418.48.153.916.131 1.26.08.385-.058 1.18-.484 1.345-.95.165-.467.165-.866.115-.95-.05-.082-.182-.133-.38-.232"/>
            </svg>
          </a>
          {site.googleBusiness && (
            <a
              href={site.googleBusiness}
              aria-label="Google Maps"
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-600 hover:text-cta transition-colors"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/>
              </svg>
            </a>
          )}
        </div>
        <p class="text-slate-600">
          <a href={`tel:${site.contact.phone}`} class="hover:text-primary">{site.contact.phoneDisplay}</a>
        </p>
        <p class="text-slate-600 mt-2">
          <a href={`mailto:${site.contact.email}`} class="hover:text-primary">{site.contact.email}</a>
        </p>
        <a href="/contact" class={site.styles.ctaButtonFooter}>
          Me contacter
        </a>
      </div>
    </div>

    <div class="text-center text-xs text-slate-500 mt-12 pt-8 border-t">
      <p>© {site.legal.copyrightYear} {site.name} — Tous droits réservés</p>
      <p class="mt-2">
        <a href="/mentions-legales" class="underline hover:text-primary">Mentions légales</a>
      </p>
    </div>
  </div>
</footer>
